generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(cuid())
  googleId      String?            @unique
  email         String             @unique
  avatarUrl     String?
  createdAt     DateTime           @default(now())
  plan          String             @default("pro")
  emailVerified Boolean            @default(false)
  passport      Passport?
  notifications UserNotification[]
  aiModelKeys   AIModelAPIKey[]
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

model Passport {
  id               String            @id
  userId           String            @unique
  username         String?           @unique
  displayName      String
  publicKey        String
  privateKey       String
  createdAt        DateTime          @default(now())
  webhookUrl       String?
  apiKeys          ApiKey[]
  monitors         Monitor[]
  user             User              @relation(fields: [userId], references: [id])
  stamps           Stamp[]
  takedowns        Takedown[]
  webhookEndpoints WebhookEndpoint[]
}

model ApiKey {
  id         String    @id @default(cuid())
  passportId String
  name       String?
  keyPrefix  String
  keyHash    String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  passport   Passport  @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@index([passportId])
}

model Stamp {
  id                          String         @id
  passportId                  String
  originalHash                String
  stampedHash                 String?
  pHash                       String?
  dHash                       String?
  title                       String
  description                 String?
  license                     String
  category                    String         @default("image")
  fileType                    String
  fileName                    String?
  fileSize                    Int?
  originalFileUrl             String
  stampedFileUrl              String?
  thumbnailUrl                String?
  signature                   String
  certificateUrl              String?
  metadataJson                String?
  proofChain                  String?
  aiOptOut                    Boolean        @default(true)
  monitorEnabled              Boolean        @default(false)
  createdAt                   DateTime       @default(now())
  audioFingerprint            String?
  c2paEnabled                 Boolean        @default(true)
  c2paManifestUrl             String?
  creatorAttestationAt        DateTime?
  creatorAttestationName      String?
  creatorAttestationPayload   String?
  creatorAttestationSignature String?
  creatorAttestationStatement String?
  creatorDeclarationUrl       String?
  embedding                   Float[]
  evidenceCertificateUrl      String?
  tsaChainJson                String?
  tsaProviderName             String?
  tsaTier                     String?        @default("development")
  tsaTimestamp                DateTime?
  tsaToken                    Bytes?
  tsaUrl                      String?
  tsaVerifyStatus             String?
  videoFingerprint            String?
  creatorAttestationCity      String?
  creatorAttestationCountry   String?
  tsaStatus                   String?        @default("pending")
  processing                  Boolean        @default(true)
  monitors                    Monitor[]
  alerts                      MonitorAlert[]
  passport                    Passport       @relation(fields: [passportId], references: [id])
  stampAnchors                StampAnchor[]
  versions                    StampVersion[]
  takedowns                   Takedown[]
  aiAccessTokens              AIAccessToken[]
  aiRegistryMonitors          AIRegistryMonitor[]
  aiTrainingDetections        AITrainingDetection[]
  trainingDataAudits          TrainingDataAudit[]

  @@index([pHash])
  @@index([originalHash])
  @@index([passportId])
  @@index([aiOptOut])
}

model StampVersion {
  id           String   @id @default(cuid())
  stampId      String
  version      Int
  label        String
  fileHash     String
  fileUrl      String
  thumbnailUrl String?
  fileSize     Int?
  note         String?
  createdAt    DateTime @default(now())
  chainHash    String?
  prevHash     String?
  signature    String?
  stamp        Stamp    @relation(fields: [stampId], references: [id], onDelete: Cascade)

  @@unique([stampId, version])
  @@index([stampId])
}

model Monitor {
  id            String         @id @default(cuid())
  passportId    String
  stampId       String
  status        String         @default("active")
  lastScanAt    DateTime?
  matchCount    Int            @default(0)
  createdAt     DateTime       @default(now())
  nextScanAt    DateTime?
  scanFrequency String         @default("weekly")
  passport      Passport       @relation(fields: [passportId], references: [id])
  stamp         Stamp          @relation(fields: [stampId], references: [id], onDelete: Cascade)
  alerts        MonitorAlert[]

  @@unique([passportId, stampId])
  @@index([status])
  @@index([nextScanAt])
}

model MonitorAlert {
  id            String    @id @default(cuid())
  monitorId     String
  stampId       String
  sourceUrl     String
  sourceName    String?
  matchType     String
  confidence    Float
  screenshotUrl String?
  status        String    @default("new")
  createdAt     DateTime  @default(now())
  externalId    String?
  sourceEngine  String?
  monitor       Monitor   @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  stamp         Stamp     @relation(fields: [stampId], references: [id], onDelete: Cascade)
  takedown      Takedown?

  @@index([monitorId])
  @@index([stampId])
  @@index([status])
  @@index([externalId])
}

model Takedown {
  id               String        @id @default(cuid())
  passportId       String
  stampId          String
  alertId          String?       @unique
  platform         String
  infringingUrl    String
  status           String        @default("draft")
  dmcaLetter       String?
  filedAt          DateTime?
  resolvedAt       DateTime?
  resolution       String?
  notes            String?
  createdAt        DateTime      @default(now())
  autoSubmitted    Boolean       @default(false)
  escalatedAt      DateTime?
  externalTicketId String?
  responseDeadline DateTime?
  submissionMethod String?
  alert            MonitorAlert? @relation(fields: [alertId], references: [id])
  passport         Passport      @relation(fields: [passportId], references: [id])
  stamp            Stamp         @relation(fields: [stampId], references: [id], onDelete: Cascade)

  @@index([passportId])
  @@index([stampId])
  @@index([status])
  @@index([responseDeadline])
}

model BlockchainAnchor {
  id                String        @id @default(cuid())
  chain             String
  txHash            String
  merkleRoot        String
  stampCount        Int           @default(0)
  anchoredAt        DateTime
  createdAt         DateTime      @default(now())
  auditHeadHash     String?
  blockchainStatus  String        @default("pending")
  otsConfirmedBytes Bytes?
  otsPendingBytes   Bytes?
  stamps            StampAnchor[]

  @@index([merkleRoot])
}

model StampAnchor {
  id          String           @id @default(cuid())
  stampId     String
  anchorId    String
  merkleProof String
  leafHash    String
  createdAt   DateTime         @default(now())
  anchor      BlockchainAnchor @relation(fields: [anchorId], references: [id], onDelete: Cascade)
  stamp       Stamp            @relation(fields: [stampId], references: [id], onDelete: Cascade)

  @@unique([stampId, anchorId])
  @@index([stampId])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

model WebhookEndpoint {
  id         String            @id @default(cuid())
  passportId String
  url        String
  secret     String
  label      String?
  enabled    Boolean           @default(true)
  createdAt  DateTime          @default(now())
  deliveries WebhookDelivery[]
  passport   Passport          @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@index([passportId])
}

model WebhookDelivery {
  id          String          @id @default(cuid())
  endpointId  String
  event       String
  payloadJson String
  status      String          @default("pending")
  attempts    Int             @default(0)
  nextRetryAt DateTime?
  lastError   String?
  createdAt   DateTime        @default(now())
  endpoint    WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([endpointId])
}

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  passportId      String?
  stampId         String?
  action          String
  metadataJson    String?
  ipAddress       String?
  userAgent       String?
  previousLogHash String?
  entryHash       String
  createdAt       DateTime @default(now())

  @@index([stampId])
  @@index([passportId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// AI Training Protection Models
model AIAccessToken {
  id              String    @id @default(cuid())
  stampId         String
  stamp           Stamp     @relation(fields: [stampId], references: [id], onDelete: Cascade)
  tokenHash       String    @unique
  tokenPrefix     String    @unique
  purpose         String    @default("license_verification") // license_verification, training_opt_out, model_provenance
  licenseType     String    @default("all-rights-reserved") // all-rights-reserved, cc-by, cc-by-sa, cc-by-nd, cc-by-nc, cc-by-nc-sa, cc-by-nc-nd
  restrictions    String    @db.Text // JSON: {allowAI, allowCommercial, allowModification, attribution_required}
  metadata        String?   @db.Text // JSON: {model_ids, dataset_names, usage_context}
  issuedAt        DateTime  @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  verificationCount Int     @default(0)
  lastVerifiedAt  DateTime?
  createdAt       DateTime  @default(now())

  @@index([stampId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model AIRegistryMonitor {
  id              String    @id @default(cuid())
  stampId         String
  stamp           Stamp     @relation(fields: [stampId], references: [id], onDelete: Cascade)
  monitoringPlatforms String @db.Text // JSON: {hugging_face, replicate, stability_ai, civitai, modelforge, kaggle}
  isActive        Boolean   @default(true)
  lastScanAt      DateTime?
  nextScanAt      DateTime?
  scanFrequency   String    @default("weekly") // hourly, daily, weekly, monthly
  detectionCount  Int       @default(0)
  createdAt       DateTime  @default(now())
  detections      AITrainingDetection[]

  @@index([stampId])
  @@index([isActive])
  @@index([nextScanAt])
}

model AITrainingDetection {
  id              String    @id @default(cuid())
  registryMonitorId String
  registryMonitor AIRegistryMonitor @relation(fields: [registryMonitorId], references: [id], onDelete: Cascade)
  stampId         String
  stamp           Stamp     @relation(fields: [stampId], references: [id], onDelete: Cascade)
  platform        String    // hugging_face, replicate, stability_ai, civitai, kaggle
  modelId         String
  modelName       String
  modelUrl        String    @db.Text
  detectionMethod String    // hash_match, embedding_similarity, metadata_analysis
  confidence      Float     // 0-1 confidence score
  datasetName     String?
  datasetUrl      String?   @db.Text
  detectedAt      DateTime  @default(now())
  reportedAt      DateTime?
  responseStatus  String    @default("new") // new, investigating, contacted, resolved, ignored
  platformResponse String?  @db.Text
  internalNotes   String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([stampId])
  @@index([registryMonitorId])
  @@index([platform])
  @@index([responseStatus])
  @@index([detectedAt])
}

model AIModelAPIKey {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        String    // hugging_face, replicate, stability_ai, civitai, kaggle
  keyHash         String    @unique
  keyPrefix       String
  label           String?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([platform])
}

model TrainingDataAudit {
  id              String    @id @default(cuid())
  stampId         String
  stamp           Stamp     @relation(fields: [stampId], references: [id], onDelete: Cascade)
  auditType       String    // usage_in_dataset, model_training, fine_tuning, embedding_generation
  platform        String
  detectionHash   String    // hash of where detected (file path, model id, etc)
  evidence        String    @db.Text // JSON evidence blob
  severity        String    @default("high") // low, medium, high, critical
  actionTaken     String?   // sent_takedown, contacted_platform, legal_notice
  resolutionDate  DateTime?
  createdAt       DateTime  @default(now())

  @@index([stampId])
  @@index([platform])
  @@index([auditType])
}
