# Database
DATABASE_URL=postgresql://user:password@localhost:5432/proofstamp

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_change_this

# Encryption key for private keys at rest — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENCRYPTION_KEY=your_64_char_hex_key

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Services
STEGO_SERVICE_URL=http://localhost:8000
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001
PORT=3001

# Rate limiting (defaults shown)
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_STAMP_HOURLY_MAX=20
WEBHOOK_RETRY_INTERVAL_MS=60000
WEBHOOK_LEGACY_SECRET=change-me-for-legacy-single-url-webhooks

# RFC 3161 Timestamp Authority (required for stamps unless TSA_OPTIONAL=true)
# development = FreeTSA or any configured URL (default). production = commercial TSA URL required.
TSA_MODE=development
TSA_URL=https://freetsa.org/tsr
TSA_PROVIDER_NAME=FreeTSA (development)
# PEM bundle for full PKCS#7 signature verification (bundled FreeTSA CA if unset)
TSA_CA_CERT_PATH=./certs/freetsa-cacert.pem
# TSA_CA_CERT_PEM="-----BEGIN CERTIFICATE-----..."
# Commercial TSA (DigiCert/GlobalSign): set TSA_MODE=production and your commercial TSA_URL
# TSA_ALLOW_FREE_IN_PROD=true  # escape hatch only

# Legal proof (all users get full stack)
LEGAL_PROOF_DISABLED=false
TSA_OPTIONAL=false
LEGAL_SIGNATORY_NAME=ProofStamp System Records Officer
LEGAL_SIGNATORY_TITLE=Evidence Systems (Computer Output)
LEGAL_SIGNATORY_ORG=ProofStamp
AUDIT_LOG_RETENTION_DAYS=365
# Monthly stamp limit per user. Defaults to 500 if unset.
STAMP_FAIR_USE_MONTHLY=500

# Rate limits (per IP) — tuned for ~200–300 concurrent users behind a load balancer
# TRUST_PROXY=true  # set when behind nginx/render/heroku
# RATE_LIMIT_GLOBAL_MAX=2000
# RATE_LIMIT_STAMP_WRITE_MAX=30
# RATE_LIMIT_STAMP_READ_MAX=300
# RATE_LIMIT_EMAIL_SEND_MAX=15
# Set to true ONLY to disable fair use entirely (not recommended for production)
STAMP_QUOTA_DISABLED=false
BLOCKCHAIN_ANCHOR_DISABLED=false
TSA_RETRY_INTERVAL_MS=900000
TSA_REQUEST_TIMEOUT_MS=10000
TSA_RETRY_DISABLED=false
# Platform RSA signing key (PEM). Auto-generated under server/certs/platform/ if unset.
# PLATFORM_PUBLIC_KEY_PEM=
# PLATFORM_PRIVATE_KEY_PEM=
# External audit head anchor (optional)
# GITHUB_AUDIT_TOKEN=
# GITHUB_AUDIT_REPO=youruser/proofstamp-audit-heads

# Reverse image monitoring (optional)
TINEYE_API_KEY=
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_CREDENTIALS_PATH=

# SMTP — email signup/login codes and optional alert emails
# Without SMTP, codes are logged to the server console (development only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@proofstamp.io
# SMTP_SECURE=true  # use for port 465
RESEND_API_KEY=
