  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --watch ../prisma/schema.prisma -e js,prisma --exec \"npm run prisma:generate && node src/index.js\"",
    "start": "npm run prisma:generate && node src/index.js",
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "prisma generate --schema=../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=../prisma/schema.prisma"
  },
